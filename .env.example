# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Embeddings (local sentence-transformers model)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Pipeline
TOP_N_JOBS=10
JOB_SOURCE=all
DISPLAY_PAGE_SIZE=10
MAX_PAGE_SIZE=15
RECENT_JOBS_DAYS=7
EXPERIENCE_FLEX_YEARS=2

# Daily morning scan (runs while API server is up)
DAILY_SCAN_ENABLED=true
DAILY_SCAN_HOUR=8
DAILY_SCAN_MINUTE=0

# Notifications (local writes to logs/notifications/; whatsapp when configured)
NOTIFIER_BACKEND=local
WHATSAPP_ENABLED=false
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_RECIPIENT=

# Storage
DATABASE_URL=sqlite:///data/careerpilot.db
CHROMA_PATH=data/chroma

# API
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
